@model TRS.ViewModels.TrainingScheduleViewModel
@{
    ViewData["Title"] = "Training Schedule";
    ViewBag.FormID = "TRTT-0001";
}
@* Make sure tag helpers are not available for the Window content *@
@removeTagHelper "*, Microsoft.AspNet.Mvc.Razor"
@removeTagHelper "*, Microsoft.AspNetCore.Mvc.Razor"


<div class="card card-secondary">
    <div class="card-header" >
        <h3 class="card-title">
            <i class="fas fa-calendar"></i>
            Training Scheduling
        </h3>
        <div class="card-tools">
            <button type="button" class="btn btn-tool" data-card-widget="collapse"><i class="fas fa-minus"></i>
            </button>
        </div>
    </div>
    <div class="card-body">
        <div class="overlay-wrapper">
            <div class="overlay dark loadingSpinner" style="display: none;"><i class="fas fa-3x fa-sync-alt fa-spin"></i></div>
@(
            Html.Kendo().Grid(Model.TrainingScheduleList)
            .Selectable()
            .Name("grid_trainingScheduleList")
            .HtmlAttributes(new {data_form = "Schedule" })
            .NoRecords()
            .Height(500)
            .Columns(columns =>
            {
                columns.Bound(m => m.Program.ProgramTitle).Title("PROGRAM TITLE").HeaderHtmlAttributes(new { style = "text-align:center; font-weight:bold;" }).Width(180);
                columns.Bound(m => m.Course.CourseTitle).Title("COURSE TITLE").HeaderHtmlAttributes(new { style = "text-align:center; font-weight:bold;" }).Width(180);   
                columns.Bound(m => m.TrainingCode).Title("TRAINING CODE").HeaderHtmlAttributes(new { style = "text-align:center; font-weight:bold;" }).Width(220);
                columns.Bound(m => m.FormattedDate).Title("DATE").HeaderHtmlAttributes(new { style = "text-align:center; font-weight:bold;" }).Width(180);
                columns.Bound(m => m.FormattedTime).Title("TIME").HeaderHtmlAttributes(new { style = "text-align:center; font-weight:bold;" }).Width(150);
                columns.Bound(m => m.Region).Title("REGION").HeaderHtmlAttributes(new { style = "text-align:center; font-weight:bold;" }).Width(150);
                columns.Bound(m => m.TrainingType).Title("TRAINING TYPE").HeaderHtmlAttributes(new { style = "text-align:center; font-weight:bold;" }).Width(180);      
                columns.Bound(m => m.ResourceSpeaker).Title("RESOURCE SPEAKER").HeaderHtmlAttributes(new { style = "text-align:center; font-weight:bold;" }).Width(180);      
                columns.Bound(m => m.FormattedJobClasses).Title("JOB CLASS").HeaderHtmlAttributes(new { style = "text-align:center; font-weight:bold;" }).Width(300);
                columns.Bound(m => m.ScheduleStatus).Title("TRAINING SCHEDULE STATUS").HeaderHtmlAttributes(new { style = "text-align:center; font-weight:bold;" }).Width(270);      
                columns.Command(command =>
                {
                    command.Custom("Edit").Text(" ").IconClass("k-icon k-i-pencil")
                            .HtmlAttributes(new { @class = "k-button-outline-info btn_action_edit",
                                title = "Edit"})
                            .Click("grid_onClick_edit");
                    command.Custom("Cancel").Text(" ").IconClass("k-icon k-i-x")
                            .HtmlAttributes(new { @class = "k-button-outline-error btn_action_cancel",
                                title = "Cancel"})
                            .Click("grid_onClick_cancel")
                            ;
                    command.Custom("Publish").Text(" ").IconClass("fa fa-paper-plane")
                            .HtmlAttributes(new { @class = "k-button-outline-success btn_action_publish",
                                title = "Publish"})
                            .Click("grid_onClick_publish")
                            ;
                }).Width(150).Title("ACTION").Sticky()
                .HeaderHtmlAttributes(new { style = "text-align:center; font-weight:bold;" });
        })
        .ToolBar(toolbar => {
            toolbar.Excel();
            }
        )
        .Editable(editable => editable
        .Mode(GridEditMode.PopUp))
        .Excel(excel => excel
            .FileName("TrainingScheduleList.xlsx") // Specify the filename for the exported Excel file
            .AllPages(true) // Enable export of all pages, including content before the grid
            .Filterable(false)            
        )
        .Events(events => events
            .ExcelExport("grid_onExcelExport")
            .DataBound("grid_onDataBound")                 
            .Change("grid_onChange")   
        ) // Attach the excelExport event
        .Scrollable(s => s.Height("auto"))
        .Pageable()
        .DataSource(dataSource => dataSource
            .Ajax()
            .PageSize(20)            
            .ServerOperation(true)
            .Read(read => read.Action("GetTrainingScheduleList", "TrainingSchedule").Data("ApplyFilterGrid"))
            .Model(model =>
            {
                model.Id(p => p.TrainingCode);
            })
        )
        .Resizable(resize => resize.Columns(true))
        )    
        </div>
            
    </div>
    <div class="card-footer">        
        <button type="submit" class="btn btn-info float-right" onclick="openNewEntryWindow()">
            Add Training Schedule
        </button>
    </div>
</div>


<div class="card card-secondary">
    <div class="card-header" style="display: flex; justify-content: center;">
        <h3 class="card-title">            
            Training Calendar
        </h3>
    </div>
    <div class="card-body">
        <div class="overlay-wrapper">
            <div class="overlay dark loadingSpinner" style="display: none;"><i class="fas fa-3x fa-sync-alt fa-spin"></i></div>
            @(Html.Kendo().Scheduler<CalendarActivity>()
            .Name("scheduler_trainingSchedule")
            .Date(DateTime.Now)
            .Editable(false)
            .ShowWorkHours(true)
            .WorkDayStart(8, 0, 0)                        
            .WorkDayEnd(17, 0, 0)
            .Selectable(true)                                    
            .Events(e => e.Change("scheduler_change"))            
            .Resources(resource =>
            {
                resource.Add(m => m.TrainingScheduleStatus)
                .Title("Status")
                .DataTextField("Text")
                .DataValueField("Value")
                .DataColorField("Color")
                .BindTo(new[] {       
                    new { Text = "AVAILABLE", Value = "AVAILABLE", Color = "#28a745" },
                    new { Text = "COMPLETED", Value = "COMPLETED", Color = "#6c757d" }
                });
            })
            .Views(views =>
            {
                views.DayView(wView =>
                {
                    wView.WorkDayStart( 8, 0, 0);
                    wView.WorkDayEnd(17, 0, 0);
                    wView.ShowWorkHours(true);
                    wView.Footer(true);
                });
                views.WeekView(wView =>
                {
                    wView.WorkDayStart(8, 0, 0);
                    wView.WorkDayEnd(17, 0, 0);
                    wView.ShowWorkHours(true);
                    wView.Footer(true);
                });
                views.MonthView(mView => mView.Selected(true));
            })
            .DataSource(d => d
                .Read("GetTrainingScheduleActivity", "TrainingSchedule")
            )
            )
        </div>
        
    </div>
</div>

@(Html.Kendo().Window()
    .Name("window_trainingCancellation")
    .Title("TRAINING SCHEDULE CANCELLATION")    
    .Draggable()
    .Pinned(true)    
    .Modal()
    .Visible(false)
    .Content(@<text>  
        
    </text>)    
    .Width(500)
    .Actions(actions => actions.Close())
)
<script>    
    var g_paramEmployeeNo = "",
        g_trainingCode = "";

    var g_programCodeFilter = "", 
        g_courseCodeFilter = "",
        g_regionCodeFilter = "",
        g_trainingTypeFilter = "",
        g_scheduleStatusFilter = "";

    $(document).ready(function () {

        var customToolbarPlaceholder = $("#custom-toolbar-placeholder");

        var toolbar = $("#grid_trainingScheduleList").find(".k-toolbar");
        var filtersContainer = $("<div style='display:flex;flex:auto;align-items: center;margin-left:10px;margin-right: auto; padding: 10px;'>Filters: </div>").prependTo(toolbar);

        var programFilter = $("<div style='margin-right:10px;margin-left:10px;width:200px;'></div>").appendTo(filtersContainer);
        var courseFilter = $("<div style='margin-right:10px;width:200px;'></div>").appendTo(filtersContainer);        
        var scheduleStatusFilter = $("<div style='margin-right:10px;width:200px;'></div>").appendTo(filtersContainer);
        var regionFilter = $("<div style='margin-right:10px;width:150px;'></div>").appendTo(filtersContainer);
        var trainingTypeFilter = $("<div style='margin-right:10px;width:150px;'></div>").appendTo(filtersContainer);
        var ApplyFiltersButton = $("<button class='k-button k-button-solid-primary k-button-md k-rounded-md k-button-solid k-button-solid-base k-toolbar-button'>Apply Filters</button>").appendTo(filtersContainer);


        programFilter.kendoMultiSelect({
            dataTextField: "ProgramTitle",
            dataValueField: "ProgramCode",            
            autowidth: true,
            placeholder: "PROGRAM",
            dataSource: {
                transport: {
                    read: {
                        url: '@(Url.Action("GetTrainingProgramEnumList","TrainingProgramAndCourse"))',                        
                        dataType: "json"
                    }
                }
            }
        });

        courseFilter.kendoMultiSelect({
            dataTextField: "CourseTitle",
            dataValueField: "CourseCode",          
            autowidth: true,
			placeholder: 'COURSE',            
            dataSource: {
                transport: {
                    read: {
                        url: '@(Url.Action("GetTrainingCourseEnumList","TrainingProgramAndCourse"))',
                        dataType: "json"
                    }
                }
            }
        });
        
        scheduleStatusFilter.kendoDropDownList({
            dataTextField: "text",
            dataValueField: "value",
            width: 800,
			optionLabel: 'SCHEDULE STATUS', 
            dataSource: [
                { text: "ALL", value: "ALL" },
                { text: "DRAFT", value: "DRAFT" },
                { text: "AVAILABLE", value: "AVAILABLE" },
                { text: "CANCELLED", value: "CANCELLED" },
                { text: "COMPLETED", value: "COMPLETED" }
            ]
        });

        //TODO REGION
        regionFilter.kendoDropDownList({
            dataTextField: "Region",
            dataValueField: "Region",
            width: 300,
			optionLabel: 'REGION',
            dataSource: {
                transport: {
                    read: {
                        url: '@(Url.Action("GetHRRegionList","TrainingSchedule"))',
                        dataType: "json"
                    }
                }
            }
        });

        trainingTypeFilter.kendoDropDownList({
            dataTextField: "text",
            dataValueField: "value",
            width: 300,
			optionLabel: 'TRAINING TYPE',         
            dataSource: [
                { text: "ALL", value: "ALL" },
                { text: "FACE TO FACE", value: "FACE TO FACE" },
                { text: "ONLINE", value: "ONLINE" }
            ]
        });
        
        

        ApplyFiltersButton.click(function () {
            
            // apply the filters to the grid
            g_courseCodeFilter = courseFilter.data("kendoMultiSelect").value();
            g_programCodeFilter = programFilter.data("kendoMultiSelect").value();
            g_regionCodeFilter = regionFilter.data("kendoDropDownList").value();
            g_trainingTypeFilter = trainingTypeFilter.data("kendoDropDownList").value();
            g_scheduleStatusFilter = scheduleStatusFilter.data("kendoDropDownList").value();
            
                    
            // Check if any of the filters have a value selected
            if (g_courseCodeFilter.length > 0 || 
                g_programCodeFilter.length > 0 || 
                g_regionCodeFilter !== "" || 
                g_trainingTypeFilter !== "" || 
                g_scheduleStatusFilter !== "") {
                
                // if the filters are not empty, apply them to the grid
                var grid = $("#grid_trainingScheduleList").data("kendoGrid");
                grid.dataSource.read();
            } else {
                // Show an alert if no filters are selected
                $mong.kendoAlertInfo("Please select at least one from the filter options.");
                return;
            }

        });


    });

    function ApplyFilterGrid(){
        return {            
            paramProgramCode : g_programCodeFilter,
            paramCourseCode : g_courseCodeFilter,
            paramRegionCode : g_regionCodeFilter,
            paramTrainingType : g_trainingTypeFilter,
            paramScheduleStatus : g_scheduleStatusFilter
        }
    }

        
    // In your grid_onChange function
    function grid_onChange(e) {
        
        var eventTarget = (e.target) ? $(e.target) : $(e.srcElement);
        var isAction = eventTarget.hasClass('k-command-cell');
        if (isAction)
            return;

        e.preventDefault();

        // Get the selected row
        var row = this.select();

        // Get the data item of the selected row        
        var dataItem = this.dataItem(row);  
                
        //get Training Code
        var _code = dataItem.TrainingCode
        //actions: GetTrainingScheduleWindow
        var _url = '@Url.Action("GetTrainingScheduleWindow","TrainingSchedule")';        

        var _window = $("#window_details").data("kendoWindow");
                   
        _window.title(_code);
        _window.open();         
        //add spinner
        kendo.ui.progress(_window.element, true);    
        
        //get the partial page and place it in window content
        $.get(_url, {control:"View", code:_code})
            .fail(
                function(res){                    
                    $mong.kendoAlertInfo("Something went wrong. If this is not your first time seeing this, please report this to an IT Administrator");  
                    _window.content(res.responseText); 
                    _window.center()
                }
            )
            .done(
                function(_partialPage){ //pages: _TrainingProgramDetails | _TrainingCourseDetails
                _window.content(_partialPage); 
                _window.center()
                window_details_Resize()
                }
            )
    }

    function grid_onDataBound(e) {
        var grid = this;
    
        grid.tbody.find("tr[role='row']").each(function () {
            var model = grid.dataItem(this);
            
            if (model.ScheduleStatus != "DRAFT") {
                $(this).find(".btn_action_publish").prop("disabled", true);
                $(this).find(".btn_action_publish").addClass("k-state-disabled");
            }


            if (model.ScheduleStatus == "CANCELLED") {
                $(this).find(".btn_action_cancel").prop("disabled", true);
                $(this).find(".btn_action_cancel").addClass("k-state-disabled");
                $(this).find(".btn_action_edit").prop("disabled", true);
                $(this).find(".btn_action_edit").addClass("k-state-disabled");
            }

        });
    }
    
    function grid_onClick_cancel(e){
        
        e.preventDefault();
        
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));      
        var _code = dataItem.TrainingCode;
        g_trainingCode = _code;
        
        var _window = $("#window_trainingCancellation").data("kendoWindow");

         $.get('@Url.Action("GetTrainingScheduleCancellationWindow","TrainingSchedule")')
         .done(
            function(_TrainingScheduleDetails){
                _window.content(_TrainingScheduleDetails);
                _window.open().center();
                window_details_Resize()
            }
        )  
    }

    async function grid_onClick_publish(e){
        //ask user if want to proceed saving
        const result = await $mong.kendoConfirmationDialog("Do you want to publish the training schedule?");

        //If user clicked NO, proceed below
        if (result !== true) {
            return;//exit
        }
        
        e.preventDefault();
        
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));        
                
        //get Training Code
        var _code = dataItem.TrainingCode
        
        $(".loadingSpinner").show();
        $.post('@Url.Action("PublishSchedule", "TrainingSchedule")', { paramCode:_code})
            .fail(
                function (res) {
                    $(".loadingSpinner").hide();
                    $mong.kendoAlertInfo(res.responseText);
                    return
                }
            )
            .done(
                function (data) {

                    var grid = $("#grid_trainingScheduleList").data("kendoGrid");
                    var scheduler = $("#scheduler_trainingSchedule").data("kendoScheduler");

                    scheduler.refresh();
                    scheduler.dataSource.read();

                    grid.dataSource.read().then(function () {
                        grid.refresh();
                    });
                    
                    $(".loadingSpinner").hide();

                    // Construct the mailto link
                    var cc = (data.EmailCC != ""? "&cc="+data.EmailCC: "");
                    var bcc = (data.EmailBCC != ""? "&bcc="+data.EmailBCC: "");
                    
                    window.location.href = "mailto:" + data.EmailTo                     
                        + "?subject=" + data.EmailSubject 
                        + "&body=" + data.EmailBody
                        + cc
                        + bcc;

                    $mong.kendoAlertInfo("Successfully published.");
                    return
                }
            )
    }

    function grid_onClick_edit(e){

        e.preventDefault();
        
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));        
                
        //get Training Code
        var _code = dataItem.TrainingCode
        //actions: GetTrainingScheduleWindow
        var _url = '@Url.Action("GetTrainingScheduleWindow","TrainingSchedule")';        

        var _window = $("#window_details").data("kendoWindow");
                   
        _window.title(_code);
        _window.open();         
        //add spinner
        kendo.ui.progress(_window.element, true);    
        
        //get the partial page and place it in window content
        $.get(_url, {control:"Edit", code:_code})
            .fail(
                function(res){                    
                    $mong.kendoAlertInfo("Something went wrong. If this is not your first time seeing this, please report this to an IT Administrator");  
                    _window.content(res.responseText); 
                    _window.center()
                }
            )
            .done(
                function(_partialPage){ //pages: _TrainingProgramDetails | _TrainingCourseDetails
                _window.content(_partialPage); 
                _window.center()
                window_details_Resize()
                }
            )
    }

    function openNewEntryWindow() {          
        var _url = _url = '@Url.Action("GetTrainingScheduleWindow","TrainingSchedule")'; 
        
        var _window = $("#window_details").data("kendoWindow");
                
        _window.title("TRAINING SCHEDULE");
        _window.open(); 
        //add spinner
        kendo.ui.progress(_window.element, true);

        $.get(_url, {control:"Add"})
            .fail(
                function(res){                    
                    $mong.kendoAlertInfo("Something went wrong. If this is not your first time seeing this, please report this to an IT Administrator");   
                    _window.content(res.responseText); 
                    _window.center();
                }
            )
            .done(
                function(_partialPage){ //pages: _TrainingCoordinatorDetails
                    _window.content(_partialPage);
                    _window.center();
                    window_details_Resize()
                }
            )
    }
    
    function grid_onExcelExport(e) {
        //var sheet = e.workbook.sheets[0];
        
        
        //// Add custom header rows to the exported Excel file
        //sheet.rows.unshift(            
        //    {}, // Add an empty row to create separation
        //    {}, // Add another empty row
        //    {}  // Add one more empty row
        //);

    }
    
    function CloseCancelWindow(){
        $("#window_trainingCancellation").data("kendoWindow").close();  
    }

    function scheduler_change(e) {     
        var events = e.events; //list of selected Scheduler events
        
        if(events.length == 0){
            return;
        }       

        var _window = $("#window_details").data("kendoWindow");         
        _window.open();
        _window.title(events[0].Schedule.TrainingCode);
        //add spinner
        kendo.ui.progress(_window.element, true);

        $.get('@Url.Action("GetTrainingScheduleWindow","TrainingSchedule")',{control: "View", code : events[0].ID})
        .fail(
                function(res){                    
                    $mong.kendoAlertInfo("Something went wrong. If this is not your first time seeing this, please report this to an IT Administrator");   
                    _window.content(res.responseText); 
                    _window.center(); 
                }
            )
        .done(
            function(_TrainingScheduleDetails){
                _window.content(_TrainingScheduleDetails);
                _window.center(); 
                window_details_Resize()
            }
        )
    }    
    
    
</script>