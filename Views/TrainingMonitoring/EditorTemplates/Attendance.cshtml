@model string

@(
    Html.Kendo().DropDownListFor(m=>m)            
    .HtmlAttributes(new { @style = "width: 100%", data_value_primitive = "true" })
    .BindTo(
        new List<string>(){
            "PRESENT",
            "ABSENT",
            "PARTIAL"
            }
    )
    .Events(e=>e.Change("AttendanceChange"))
)  
